# Copy this file to <your home folder>/.gama-claude.properties and fill it in.
# The plugin reads it when the first chat message is sent.

# Python from a venv that has claude-agent-sdk installed
python=C:/path/to/venv/Scripts/python.exe

# Absolute path to agent/ide_agent.py in this repo
script=C:/path/to/gama-claude-plugin/agent/ide_agent.py

# --- auth: pick ONE of the two ---
# Option A (recommended): OAuth token from your Claude subscription.
# Run `claude setup-token` once in a terminal, paste the sk-ant-oat01-... here.
oauth_token=

# Option B: pay-per-use API key from console.anthropic.com (needs credits).
key=

# Optional, default https://api.anthropic.com.
# To use a local/free model (e.g. Ollama) point this at an Anthropic<->OpenAI
# proxy such as claude-code-router (http://127.0.0.1:3456). Then set key= to any
# non-empty dummy value, leave oauth_token= blank, and set model= to the local
# model name (e.g. qwen2.5-coder:7b). Small models are weak at the tool loop.
# base_url=

# Optional. false (default) = every Edit shows an approval card with a diff in
# the chat before touching your file. true = the agent edits without asking.
# auto_approve=false

# Optional. Model for the agent. Default: claude-opus-4-8.
# model=claude-opus-4-8

# Optional. GAMA headless folder (contains gama-headless.bat/.sh) so the agent
# can compile-check and batch-run models. Auto-detected as <GAMA>/headless.
# headless_dir=C:/Users/you/AppData/Local/Programs/Gama/headless
